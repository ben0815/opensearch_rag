# Copy this file to infra/.env and adjust values as needed.
# infra/.env is read automatically by Docker Compose for variable substitution.
# Never commit infra/.env to version control.

# --- OpenSearch ---
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=change_me
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX_NAME=documents

# --- Ollama ---
OLLAMA_HOST=http://host.docker.internal:11434

# --- Models ---
EMBEDDINGS_MODEL=bge-m3
LLM_MODEL=qwen3.5:35b

# --- LLM-Parameter ---
LLM_TEMPERATURE=0.0
# Der Browser-Timeout (LLM_TIMEOUT_SECONDS + 30s) wird automatisch via chat.html injiziert.
LLM_TIMEOUT_SECONDS=240
# Kontextfenster für Ollama: 10 Chunks × ~600 Token + Prompt-Overhead ≈ 7000 Token → 16384 als sicherer Puffer
LLM_NUM_CTX=16384

# --- Embeddings ---
EMBEDDING_SIZE=1024

# --- Document processing ---
# CHUNK_SIZE und CHUNK_OVERLAP sind in Tokens (nicht Zeichen) — HuggingFace Tokenizer wird verwendet.
# Achtung: Änderung erfordert Index-Neuaufbau.
CHUNK_SIZE=400
CHUNK_OVERLAP=60
# Max. Tokens pro Chunk vor dem Embedding.
# bge-m3: bis zu 8192 Token. 600 lässt Raum für ~100 Token Nachbarkontext auf jeder Seite.
# Bei Context-Length-Fehler wird automatisch auf halbe Token-Anzahl reduziert und erneut versucht.
EMBEDDING_MAX_TOKENS=600
# HuggingFace Tokenizer-Modell — muss zum Embedding-Modell passen.
# Der Tokenizer wird beim ersten Start heruntergeladen (~1 MB) und gecacht.
TOKENIZER_MODEL_ID=BAAI/bge-m3

# --- OpenSearch Analyzer ---
# 'german': Stoppwörter + Snowball-Stemming + Normalisierung (Umlaute) — optimal für rein deutschen Text
# 'standard': sprachneutral, keine Stoppwörter
# 'english': englische Stoppwörter + Stemming
# Achtung: Änderung erfordert Index-Neuaufbau (curl -X DELETE .../documents)
OPENSEARCH_ANALYZER=german

# --- Hybrid Search (BM25 + kNN via OpenSearch normalization-processor pipeline) ---
# Pipeline wird beim App-Start automatisch in OpenSearch angelegt/aktualisiert.
# Gewichte müssen sich zu 1.0 addieren. BM25 hilft bei Eigennamen/Akronymen,
# kNN bei semantischer Ähnlichkeit.
HYBRID_SEARCH_PIPELINE_NAME=hybrid-rag-pipeline
HYBRID_BM25_WEIGHT=0.4
HYBRID_KNN_WEIGHT=0.6
# Anzahl Kandidaten, die OpenSearch zurückgibt (vor Deduplizierung)
HYBRID_K=10
# Mindest-Score für einen Treffer (0.0 = deaktiviert). Werte 0.05–0.15 filtern schwach relevante Chunks.
HYBRID_SCORE_THRESHOLD=0.1

# --- PostgreSQL ---
# PFLICHT IN PRODUKTION: Dieses Passwort ändern — 'changeme' ist nur für lokale Entwicklung.
# Wird von docker-compose sowohl für den postgres-Container als auch die DATABASE_URL verwendet.
POSTGRES_PASSWORD=changeme

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
# Pflicht in Produktion — leer lassen nur für lokale Entwicklung ohne Docker
REDIS_PASSWORD=change_me

# --- Security ---
# SECURE_COOKIES=true   # Nur aktivieren wenn die App hinter HTTPS läuft (Pflicht in Produktion)
# SECURE_COOKIES=false  # Standard: HTTP (lokale Entwicklung)
SECURE_COOKIES=false

# DEV_MODE: Aktiviert CORS für den Vite-Dev-Server (Port 5173).
# Nur für lokale Entwicklung ohne Docker — niemals in Produktion!
# DEV_MODE=true
DEV_MODE=false

# Pflicht: Langer zufälliger Schlüssel für Session-Cookie-Signierung.
# Generieren: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=change_me_generate_a_random_key

# Optionaler Fernet-Schlüssel für Verschlüsselung sensitiver app_settings (z.B. LDAP-Passwort).
# Generieren: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leer lassen = keine Verschlüsselung (akzeptabel wenn DB nicht öffentlich erreichbar)
# ENCRYPTION_KEY=

# --- Session ---
# Session-Lifetime in Stunden (wird auch in app_settings gespeichert und ist dort änderbar)
SESSION_LIFETIME_HOURS=8

# --- LDAP ---
# Diese Werte werden beim ersten Start in app_settings gespeichert und sind dann
# über die Admin-UI (/api/admin/ldap) änderbar — ohne App-Neustart.
LDAP_URL=ldap://localhost:389
LDAP_USER_SEARCH_BASE=ou=users,dc=example,dc=com
LDAP_UID_ATTR=uid
LDAP_DISPLAY_NAME_ATTR=displayName
LDAP_MAIL_ATTR=mail
LDAP_USER_FILTER=(objectClass=inetOrgPerson)
# Optional: DN der LDAP-Admin-Gruppe (leer = LDAP-Admin-Check deaktiviert)
LDAP_ADMIN_GROUP_DN=
# Optional: Service-Account für den initialen LDAP-Bind (leer = User-DN-Bind)
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
# LDAP_ENABLED=true

# --- App server ---
# APP_HOST=0.0.0.0
# APP_PORT=8081
# Bind-Adresse für den App-Port auf dem Host.
# Dev (Standard): alle Interfaces — App direkt von anderen Rechnern erreichbar.
# Prod mit Caddy: 127.0.0.1 setzen, damit nur Caddy von außen erreichbar ist.
# APP_BIND_HOST=0.0.0.0
