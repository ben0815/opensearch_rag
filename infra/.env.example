# Copy this file to infra/.env and adjust values as needed.
# infra/.env is read automatically by Docker Compose for variable substitution.
# Never commit infra/.env to version control.

# --- OpenSearch ---
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=change_me
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX_NAME=documents

# --- Ollama ---
OLLAMA_HOST=http://host.docker.internal:11434
EMBEDDER_TYPE=ollama
LLM_TYPE=ollama

# --- Models ---
EMBEDDINGS_MODEL=mxbai-embed-large
LLM_MODEL=qwen3.5:122b

# --- Embeddings ---
EMBEDDING_PROVIDER=ollama
EMBEDDING_SIZE=1024

# --- Document processing ---
# CHUNK_SIZE und CHUNK_OVERLAP sind in Tokens (nicht Zeichen) — HuggingFace Tokenizer wird verwendet.
# Achtung: Änderung erfordert Index-Neuaufbau.
CHUNK_SIZE=400
CHUNK_OVERLAP=40
# Max. Tokens pro Chunk vor dem Embedding.
# mxbai-embed-large: 512 Token Limit (BERT WordPiece). 480 lässt Puffer für [CLS]/[SEP]-Token.
# Bei Context-Length-Fehler wird automatisch auf halbe Token-Anzahl reduziert und erneut versucht.
EMBEDDING_MAX_TOKENS=480
# HuggingFace Tokenizer-Modell — muss zum Embedding-Modell passen.
# Der Tokenizer wird beim ersten Start heruntergeladen (~1 MB) und gecacht.
TOKENIZER_MODEL_ID=mixedbread-ai/mxbai-embed-large-v1

# --- OpenSearch Analyzer ---
# 'german': Stoppwörter + Snowball-Stemming + Normalisierung (Umlaute) — optimal für rein deutschen Text
# 'standard': sprachneutral, keine Stoppwörter
# 'english': englische Stoppwörter + Stemming
# Achtung: Änderung erfordert Index-Neuaufbau (curl -X DELETE .../documents)
OPENSEARCH_ANALYZER=german

# --- Hybrid Search (BM25 + kNN via OpenSearch normalization-processor pipeline) ---
# Pipeline wird beim App-Start automatisch in OpenSearch angelegt/aktualisiert.
# Gewichte müssen sich zu 1.0 addieren. BM25 hilft bei Eigennamen/Akronymen,
# kNN bei semantischer Ähnlichkeit.
HYBRID_SEARCH_PIPELINE_NAME=hybrid-rag-pipeline
HYBRID_BM25_WEIGHT=0.3
HYBRID_KNN_WEIGHT=0.7
# Anzahl Kandidaten, die OpenSearch zurückgibt (vor Deduplizierung)
HYBRID_K=10

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- App server (optional, defaults shown) ---
# APP_HOST=0.0.0.0
# APP_PORT=8081

# --- Vector store path (optional, local dev only) ---
# VECTOR_STORE_PATH=vector_store

# --- Optional: OpenAI (only if EMBEDDING_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-...
# OPENAI_ORGANIZATION=org-...

# --- Optional: AWS Bedrock (only if EMBEDDER_TYPE=bedrock or LLM_TYPE=bedrock) ---
# AWS_REGION=us-east-1
# AWS_ENDPOINT_URL=
# BEDROCK_MODEL_ID=amazon.titan-embed-text-v1
# BEDROCK_LLM_MODEL_ID=anthropic.claude-v2
